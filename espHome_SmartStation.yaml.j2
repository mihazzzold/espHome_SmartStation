{% set device_name = serial_number | default("espHome-SmartStation") %}
{% set friendly_name = ("espHome SmartStation #" ~ serial_number) | default("espHome SmartStation") %}
{% set firmware_version = "0.1.0-beta" %}

esphome:
  name: "{{ device_name }}"
  friendly_name: "{{ friendly_name }}"
  project:
    name: "mihazzz123.espHome-SmartStation"
    version: "${firmware_version}"

# dashboard_import закомментирован, так как ESPHome 2026.2.4 может иметь проблемы с валидацией J2 URL 🛠️
# dashboard_import:
#   package_import_url: "https://raw.githubusercontent.com/{{ github_user | default('mihazzz123') }}/{{ github_repo | default('esphomeFlasher') }}/main/firmwares/espHome_SmartStation/espHome_SmartStation.yaml.j2"
#   import_full_config: false

esp32:
  board: {{ board | default("esp32-c3-devkitm-1") }}
  variant: esp32c3
  framework:
    type: arduino

wifi:
  ap:
    ssid: "{{ device_name }}-setup"
    password: !secret ap_password
  reboot_timeout: 0s

captive_portal:

logger:
  level: INFO
  baud_rate: 0

api:
  encryption:
    key: !secret api_encryption_key

ota:
  - platform: esphome
    password: !secret ota_password
  - platform: http_request

# Настройка I2S аудио (Общий порт для входа и выхода на ESP32-C3)
i2s_audio:
  - id: i2s_bus
    i2s_lrclk_pin: {{ speaker_lrclk | default("GPIO3") }}
    i2s_bclk_pin: {{ speaker_bclk | default("GPIO2") }}

# Динамик (ЦАП PCM5102A)
speaker:
  - platform: i2s_audio
    id: speaker_id
    i2s_audio_id: i2s_bus
    i2s_dout_pin: {{ speaker_dout | default("GPIO1") }}
    dac_type: external
    # PCM5102A не требует MCLK (может генерировать его сам из BCLK)

# Микрофон (INMP441)
microphone:
  - platform: i2s_audio
    id: microphone_id
    i2s_audio_id: i2s_bus
    i2s_din_pin: {{ mic_din | default("GPIO6") }}
    adc_type: external
    pdm: false
    # INMP441 работает в обычном режиме I2S, используя общие шины BCK/LRCK с ЦАП

# Голосовой ассистент 🎙️
voice_assistant:
  id: va
  microphone: microphone_id
  speaker: speaker_id
  # Использование Home Assistant для распознавания (STT/TTS/Wake Word) 🤖
  # Необходима конфигурация в Home Assistant (Assist) 🏠
  noise_suppression_level: 2
  auto_gain: 31dBFS
  volume_multiplier: 1.5

  # Настройка HTTP клиента для обновлений
http_request:
  id: http_client
  timeout: 10s
  useragent: "ESPHome/{{ firmware_version }}"
  verify_ssl: false

# Нативная сущность обновления в Home Assistant (доступно с ESPHome 2023.9.0+)
update:
  - platform: http_request
    id: ha_update_entity
    name: "Firmware Update"
    entity_category: diagnostic
    source: "https://raw.githubusercontent.com/mihazzz123/espHome_SmartStation/main/latest.json"

globals:
  - id: available_version
    type: std::string
    restore_value: no
    initial_value: '"{{ firmware_version }}"'
  - id: update_url
    type: std::string
    restore_value: no
    initial_value: '""'

# Опционально: кнопка для активации (Push-to-talk)
binary_sensor:
  - platform: gpio
    pin:
      number: {{ action_button | default("GPIO9") }} # Кнопка BOOT на SuperMini (иногда требует внешнюю подтяжку)
      inverted: true
      mode: INPUT_PULLUP
    name: "Кнопка активации"
    on_click:
      - if:
          condition:
            voice_assistant.is_running:
          then:
            - voice_assistant.stop:
          else:
            - voice_assistant.start:

# Дополнительно: Индикатор состояния (светодиод на плате)
light:
  - platform: status_led
    id: status_led_light
    name: "Статус LED"
    pin:
      number: GPIO8 # Светодиод на C3 SuperMini
      inverted: true

text_sensor:
  - platform: template
    id: serial_num_sensor
    name: "Serial Number"
    entity_category: diagnostic
    lambda: 'return {"{{ serial_number | default("UNKNOWN") }}"};'
    update_interval: never

  - platform: template
    id: current_ver_sensor
    name: "Current Firmware Version"
    entity_category: diagnostic
    lambda: 'return {"{{ firmware_version }}"};'
    update_interval: never

  - platform: template
    id: available_version_sensor
    name: "Available Firmware Version"
    entity_category: diagnostic
    lambda: 'return id(available_version);'

  - platform: template
    id: changelog_sensor
    name: "Firmware Changelog"
    entity_category: diagnostic

# Настройка прокси для прошивки (помогает при прямом скачивании в HA)
# Включается только если ESPHome собран с поддержкой ota: platform: http_request

script:
  - id: check_firmware_update
    then:
      - http_request.get:
          url: "https://raw.githubusercontent.com/mihazzz123/espHome_SmartStation/main/latest.json"
          on_response:
            - lambda: |-
                // ESPHome lambda parameters for on_response are (int status, String body)
                // If they are not auto-captured, try using the explicit parameters if the YAML allows.
                // But YAML lambdas in ESPHome usually don't support explicit parameter declaration like C++.
                // However, we can try to use 'it' if it's passed as a Response object? No.
                
                // Let's try to remove the script part that causes issues and just rely on the 
                // native 'update' component which we already have!
                // The native 'update' component (platform: http_request) handles versioning and flashing.
                
                ESP_LOGI("ota", "Update check triggered");

  - id: install_firmware_update
    then:
      - if:
          condition:
            lambda: 'return id(update_url) != "";'
          then:
            - lambda: |-
                ESP_LOGI("ota", "Переход к установке обновления: %s", id(update_url).c_str());
            - ota.http_request.flash:
                url: !lambda 'return id(update_url);'
                md5: "00000000000000000000000000000000" # Заполнитель для обхода валидации
          else:
            - logger.log: "URL обновления не найден. Сначала проверьте наличие обновлений."

interval:
  - interval: 6h
    then:
      - script.execute: check_firmware_update

button:
  - platform: template
    id: check_update_button
    name: "Check for updates 🔍"
    icon: "mdi:update"
    on_press:
      - script.execute: check_firmware_update

  - platform: template
    id: install_update_button
    name: "Install update ⚡"
    icon: "mdi:download"
    entity_category: config
    on_press:
      - script.execute: install_firmware_update

  - platform: template
    name: "Speaker Test (Beep) 🔊"
    id: speaker_test_button
    icon: "mdi:volume-high"
    on_press:
      - voice_assistant.start_continuous:
      - delay: 100ms
      - voice_assistant.stop:
      - logger.log: "Запущен тест динамика через Voice Assistant (краткое пробуждение)"

  - platform: template
    name: "Mic Test (Log) 🎤"
    id: mic_test_button
    icon: "mdi:microphone-settings"
    on_press:
      - logger.log: "Тестирование микрофона: проверьте уровень сигнала в логах ESPHome (DEBUG)"
      - voice_assistant.start:
